legacy-peer-deps=true

# Netlify installs with pnpm, whose isolated node_modules can't resolve "phantom"
# (undeclared) transitive imports that npm's flat layout used to hoist — e.g.
# @web3auth/no-modal importing @toruslabs/ethereum-controllers, and
# scripts/generate-blog-manifest.mjs importing esbuild (a Vite transitive dep).
# A hoisted, npm-like layout makes those resolvable. This changes only the
# node_modules layout, NOT the locked dependency versions, so the build still
# installs with --frozen-lockfile against the existing pnpm-lock.yaml.
node-linker=hoisted
shamefully-hoist=true
