# scripts/ holds local scratch, EXCEPT build-time scripts which must ship —
# `npm run build` runs them in CI (a bare `scripts/` dir rule can't be
# negated, hence the `scripts/*` form). generate-blog-manifest.mjs was once
# written without this exception and silently never shipped, freezing the
# bot-visible blog at Feb 2026 — keep every build-referenced script negated.
scripts/*
!scripts/check-entry-bundle.mjs
!scripts/generate-blog-manifest.mjs